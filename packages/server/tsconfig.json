{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@project-sanderson/shared": ["../shared/dist"],
      "@project-sanderson/shared/*": ["../shared/dist/*"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "paths": {
        "@project-sanderson/shared": ["../shared/dist"],
        "@project-sanderson/shared/*": ["../shared/dist/*"]
      }
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
